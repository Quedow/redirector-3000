{
    "manifest_version": 3,
    "name": "Redirector 3000",
    "version": "1.0",
    "description": "Replaces request URL parts according to custom rules.",
    "permissions": [
        "storage",
        "declarativeNetRequest",
        "declarativeNetRequestFeedback",
        "notifications"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "service.js"
    },
    "options_page": "popup.html?view=full",
    "action": {
        "default_title": "Redirector 3000",
        "default_popup": "popup.html?view=popup"
    },
    "icons": {
        "32": "icons/icon-32.png",
        "192": "icons/icon-192.png",
        "512": "icons/icon-512.png"
    }
}
